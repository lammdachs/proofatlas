{
  "defaults": {
    "batch_size_bytes": 8388608,
    "accumulate_steps": 1,
    "max_epochs": 100,
    "val_ratio": 0.1,
    "patience": 10,
    "margin": 0.1,

    "optimizer": "adamw",
    "learning_rate": 0.0003,
    "weight_decay": 1e-4,
    "betas": [0.9, 0.999],
    "gradient_clip": 1.0,
    "warmup_epochs": 5,
    "samples_per_problem": 16
  },

  "configs": {
    "quick": {
      "description": "Quick training with validation",
      "max_epochs": 20,
      "val_ratio": 0.1
    },

    "long": {
      "description": "Extended training for better convergence",
      "max_epochs": 200,
      "val_ratio": 0.1
    }
  }
}
