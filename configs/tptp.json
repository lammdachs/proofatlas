{
  "version": "9.0.0",
  "source": "https://tptp.org/TPTP/Archive/TPTP-v9.0.0.tgz",
  "repo": "lammdachs/proofatlas-tptp-subset",
  "attribution": "TPTP Problem Library v9.0.0, copyright 1993-onwards Geoff Sutcliffe & Christian Suttner. https://tptp.org",

  "paths": {
    "root": ".tptp/TPTP-v9.0.0",
    "problems": ".tptp/TPTP-v9.0.0/Problems",
    "axioms": ".tptp/TPTP-v9.0.0/Axioms"
  },

  "defaults": {
    "problem_set": "bench"
  },

  "problem_sets": {
    "all": {
      "description": "All CNF/FOF problems under 64kB",
      "format": ["cnf", "fof"],
      "max_total_size_bytes": 65536
    },

    "bench": {
      "description": "Unsatisfiable and unknown problems for benchmarking",
      "format": ["cnf", "fof"],
      "max_total_size_bytes": 65536,
      "status": ["unsatisfiable", "unknown"]
    },

    "test": {
      "description": "PUZ domain problems for quick testing",
      "format": ["cnf", "fof"],
      "max_total_size_bytes": 65536,
      "domains": ["PUZ"]
    },

    "throughput16": {
      "description": "16 problems for async-inference throughput study; 2 per outcome group across (transformer_xcl_r6, mlp_xcl_r6, age_weight). Failures hit iter limit (256), not 60s wall.",
      "problems": [
        "SET/SET855-2.p", "GRP/GRP708-1.p",
        "NUM/NUM001-1.p", "NUM/NUM630+1.p",
        "CAT/CAT001-4.p", "GEO/GEO175+1.p",
        "CSR/CSR052+1.p", "REL/REL010+2.p",
        "SYN/SYN589-1.p", "SWV/SWV019-1.p",
        "CSR/CSR050+1.p", "BOO/BOO014-2.p",
        "SYN/SYN311-1.p", "SYN/SYN563-10.p",
        "SWC/SWC227+1.p", "SWW/SWW099+1.p"
      ]
    },

    "throughput_sat16": {
      "description": "16 non-solvable (iter-cap-fail under all three configs) problems for backend-saturation experiments across 8 TPTP domains.",
      "problems": [
        "GEO/GEO082+1.p", "GEO/GEO492+1.p",
        "GRP/GRP317-1.p", "GRP/GRP366-1.p",
        "LCL/LCL337-3.p", "LCL/LCL670+1.010.p",
        "NUM/NUM255-1.p", "NUM/NUM543+1.p",
        "SET/SET017-4.p", "SET/SET175-6.p",
        "SEU/SEU218+3.p", "SEU/SEU425+1.p",
        "SWC/SWC063-1.p", "SWC/SWC310-1.p",
        "SYN/SYN208-1.p", "SYN/SYN683-1.p"
      ]
    },

    "throughput32": {
      "description": "32 problems for async-inference throughput study; 4 per outcome group across (transformer_xcl_r6, mlp_xcl_r6, age_weight). Superset of throughput16; failures hit iter limit (256), not 60s wall.",
      "problems": [
        "SET/SET855-2.p", "GRP/GRP708-1.p", "MGT/MGT049-1.p", "LAT/LAT028-1.p",
        "NUM/NUM001-1.p", "NUM/NUM630+1.p", "SWC/SWC422+1.p", "ITP/ITP012+1.p",
        "CAT/CAT001-4.p", "GEO/GEO175+1.p", "RNG/RNG123+1.p", "SWV/SWV007-1.p",
        "CSR/CSR052+1.p", "REL/REL010+2.p", "FLD/FLD017-1.p", "REL/REL010-2.p",
        "SYN/SYN589-1.p", "SWV/SWV019-1.p", "SWV/SWV159+1.p", "SWV/SWV156+1.p",
        "CSR/CSR050+1.p", "BOO/BOO014-2.p", "SWC/SWC258+1.p", "ANA/ANA043-2.p",
        "SYN/SYN311-1.p", "SYN/SYN563-10.p", "FLD/FLD064-3.p", "REL/REL011-2.p",
        "SWC/SWC227+1.p", "SWW/SWW099+1.p", "PRO/PRO016+4.p", "LCL/LCL084-10.p"
      ]
    }
  }
}
